---
import T from './T.astro';
---

<section class="oi-demo section" id="demo">
  <div class="container oi-head">
    <p class="eyebrow"><T en="Live demo" zh="实时演示" /></p>
    <h2 class="section-title">
      <T en="It all happens in the notch" zh="一切都发生在灵动岛里" />
    </h2>
    <p class="section-sub">
      <T
        en="Sessions, approvals, questions, results, and a one-click jump back to the exact terminal — right where your eyes already are."
        zh="会话、审批、提问、结果，再加一键精准跳回那个终端——就在你视线本来所在的地方。"
      />
    </p>
  </div>

  <div class="oi-stage" id="oi-stage">
    <p class="sr-only">
      <T
        en="An animated illustration of the Agent Island notch: it lists agent sessions, asks for an inline approval, answers a question, and on the final step a click on a session raises that session's terminal window to the front."
        zh="Agent Island 灵动岛的动画演示：列出 Agent 会话、原地请求审批、回答提问，并在最后一步点击某个会话，把该会话对应的终端窗口调到最前。"
      />
    </p>

    <!-- ===== Laptop ===== -->
    <div class="oi-laptop">
      <div class="oi-screen" id="oi-screen" aria-hidden="true">
        <div class="oi-wall"></div>
        <div class="oi-scan"></div>

        <!-- menu bar -->
        <div class="oi-menubar">
          <div class="oi-mb-l">
            <span class="oi-mb-mark">
              <img src="/logo.png" width="14" height="14" alt="" style="display:block;border-radius:3px" />
            </span>
            <span class="oi-mb-app">Agent Island</span>
            <span class="oi-mb-menu"><span lang="en">File</span><span lang="zh">文件</span></span>
            <span class="oi-mb-menu"><span lang="en">Edit</span><span lang="zh">编辑</span></span>
            <span class="oi-mb-menu"><span lang="en">Window</span><span lang="zh">窗口</span></span>
            <span class="oi-mb-menu"><span lang="en">Help</span><span lang="zh">帮助</span></span>
          </div>
          <div class="oi-mb-r">
            <svg class="oi-mb-glyph" width="15" height="11" viewBox="0 0 24 18" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M2 6a15 15 0 0 1 20 0"></path><path d="M5.5 9.5a10 10 0 0 1 13 0"></path><path d="M9 13a5 5 0 0 1 6 0"></path><circle cx="12" cy="16" r="0.6" fill="currentColor"></circle>
            </svg>
            <svg class="oi-mb-glyph" width="22" height="11" viewBox="0 0 28 14" fill="none" stroke="currentColor" stroke-width="1.6">
              <rect x="1" y="2" width="22" height="10" rx="2.4"></rect><rect x="24.5" y="5" width="2" height="4" rx="1" fill="currentColor" stroke="none"></rect><rect x="3" y="4" width="14" height="6" rx="1" fill="currentColor" stroke="none"></rect>
            </svg>
            <span id="oi-clock">Mon 9:41 AM</span>
          </div>
        </div>

        <!-- desktop with three staggered terminal windows -->
        <div class="oi-desktop">
          <!-- back-left: Gemini -->
          <div class="oi-term oi-term-gemini" id="oi-term-gemini">
            <div class="oi-term-bar">
              <span class="oi-tl oi-tl-r"></span><span class="oi-tl oi-tl-y"></span><span class="oi-tl oi-tl-g"></span>
              <span class="oi-term-title">gemini — optimize-queries · cmux</span>
            </div>
            <div class="oi-term-body">
              <div class="oi-cr is-shown">Profiling the slow queries.</div>
              <div class="oi-ctool is-shown">Read(prisma/schema.prisma)</div>
              <div class="oi-ctree is-shown">└ 1.2 KB</div>
              <div class="oi-ctool is-shown">Edit(src/db/queries.ts)</div>
              <div class="oi-ctree is-shown">└ updated <span class="oi-ok">+8 −23</span></div>
            </div>
          </div>

          <!-- back-right: Codex -->
          <div class="oi-term oi-term-codex" id="oi-term-codex">
            <div class="oi-term-bar">
              <span class="oi-tl oi-tl-r"></span><span class="oi-tl oi-tl-y"></span><span class="oi-tl oi-tl-g"></span>
              <span class="oi-term-title">codex — backend-server · Ghostty</span>
            </div>
            <div class="oi-term-body">
              <div class="oi-cr is-shown">Building the REST endpoints.</div>
              <div class="oi-ctool is-shown">Write(src/routes/users.ts)</div>
              <div class="oi-ctree is-shown">└ new file · 47 lines</div>
              <div class="oi-ctool is-shown">Bash(npm test)</div>
              <div class="oi-ctree is-shown">└ <span class="oi-ok">3 passed</span></div>
            </div>
          </div>

          <!-- front: Claude (active session, content driven by the storyboard) -->
          <div class="oi-term oi-term-claude is-front" id="oi-term-claude">
            <div class="oi-term-bar">
              <span class="oi-tl oi-tl-r"></span><span class="oi-tl oi-tl-y"></span><span class="oi-tl oi-tl-g"></span>
              <span class="oi-term-title" id="oi-term-claude-title">claude — fix-auth-bug · iTerm2</span>
            </div>
            <div class="oi-term-body" id="oi-body-claude">
              <div class="oi-cr is-shown">Let me look at the auth module.</div>
              <div class="oi-ci is-shown">Searched 6 patterns <span class="oi-hint">ctrl+o</span></div>
              <div class="oi-ci is-shown">Read 2 files <span class="oi-hint">ctrl+o</span></div>
              <div class="oi-sp is-shown"></div>
              <div class="oi-cr is-shown">Found it — token validation skips the expiry check.</div>
            </div>
          </div>
        </div>

        <!-- the notch -->
        <div class="oi-notch-wrap">
          <div class="oi-notch" id="oi-notch" data-state="compact">
            <!-- compact / idle -->
            <div class="oi-layer is-active" data-layer="compact">
              <canvas class="oi-petc oi-petc-compact" data-pet="claude"></canvas>
              <span class="oi-compact-name">fix auth bug</span>
              <span class="oi-compact-count">3</span>
            </div>

            <!-- sessions / overview -->
            <div class="oi-layer" data-layer="sessions">
              <div class="oi-sess oi-sess-hero" data-term="claude">
                <span class="oi-pet"><canvas class="oi-petc oi-petc-hero" data-pet="claude"></canvas></span>
                <div class="oi-sess-main">
                  <div class="oi-sess-r1">
                    <span class="oi-sess-name">fix auth bug</span>
                    <span class="oi-tag">Claude</span><span class="oi-tag">iTerm2</span>
                    <span class="oi-dur">27m</span>
                  </div>
                  <div class="oi-sess-you">You: fix the auth bug in middleware</div>
                  <div class="oi-sess-status" style="color:var(--blue)">Editing middleware.ts</div>
                </div>
              </div>
              <div class="oi-sess oi-sess-mini" data-term="codex">
                <canvas class="oi-petc oi-petc-mini" data-pet="otter"></canvas>
                <span class="oi-sess-name">backend server</span>
                <span class="oi-tag">Codex</span><span class="oi-tag">Ghostty</span><span class="oi-dur">1h</span>
              </div>
              <div class="oi-sess oi-sess-mini" data-term="gemini">
                <canvas class="oi-petc oi-petc-mini" data-pet="fox"></canvas>
                <span class="oi-sess-name">optimize queries</span>
                <span class="oi-tag">Gemini</span><span class="oi-tag">cmux</span><span class="oi-dur">5h</span>
              </div>
            </div>

            <!-- approval -->
            <div class="oi-layer" data-layer="approval">
              <div class="oi-appr-head">
                <span class="oi-pulse"></span>
                <span><T en="Permission request" zh="权限请求" /></span>
              </div>
              <div class="oi-appr-tool">
                <span class="oi-appr-warn">⚠</span>
                <span class="oi-appr-name">Edit</span>
                <span class="oi-appr-path">src/auth/middleware.ts</span>
              </div>
              <div class="oi-diff">
                <div class="oi-diff-l"><span class="oi-diff-ln">12</span><span>const verify = (token) =&gt;</span></div>
                <div class="oi-diff-l oi-diff-del"><span class="oi-diff-ln">13</span><span>- jwt.verify(token)</span></div>
                <div class="oi-diff-l oi-diff-add"><span class="oi-diff-ln">13</span><span>+ if (!token) throw new</span></div>
                <div class="oi-diff-l oi-diff-add"><span class="oi-diff-ln">14</span><span>+   AuthError('missing')</span></div>
              </div>
              <div class="oi-appr-btns">
                <div class="oi-appr-btn oi-btn-deny" id="oi-deny"><T en="Deny" zh="拒绝" /> <span class="oi-kbd">⌘N</span></div>
                <div class="oi-appr-btn oi-btn-allow" id="oi-allow"><T en="Allow" zh="允许" /> <span class="oi-kbd">⌘Y</span></div>
              </div>
            </div>

            <!-- ask -->
            <div class="oi-layer" data-layer="ask">
              <div class="oi-ask-head">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                <span><T en="Claude asks" zh="Claude 提问" /></span>
              </div>
              <div class="oi-ask-q">Which package manager?</div>
              <div class="oi-opts">
                <div class="oi-opt" data-idx="0" data-label="pnpm"><span class="oi-num">⌘1</span><span>pnpm</span></div>
                <div class="oi-opt" data-idx="1" data-label="npm"><span class="oi-num">⌘2</span><span>npm</span></div>
                <div class="oi-opt" data-idx="2" data-label="bun"><span class="oi-num">⌘3</span><span>bun</span></div>
              </div>
            </div>

            <!-- approved feedback -->
            <div class="oi-layer" data-layer="approved">
              <span class="oi-approved-check">✓</span>
              <span id="oi-approved-label">Allowed</span>
            </div>

            <!-- jump: same sessions, hero done + click-to-jump -->
            <div class="oi-layer" data-layer="jump">
              <div class="oi-sess oi-sess-hero oi-sess-hl" data-term="claude">
                <span class="oi-pet"><canvas class="oi-petc oi-petc-hero" data-pet="claude"></canvas></span>
                <div class="oi-sess-main">
                  <div class="oi-sess-r1">
                    <span class="oi-sess-name">fix auth bug</span>
                    <span class="oi-tag">Claude</span><span class="oi-tag">iTerm2</span>
                    <span class="oi-dur">28m</span>
                  </div>
                  <div class="oi-sess-you">You: fix the auth bug in middleware</div>
                  <div class="oi-sess-status" style="color:var(--green)">
                    <span lang="en">Done · click to jump</span><span lang="zh">完成 · 点击跳回</span>
                  </div>
                </div>
              </div>
              <div class="oi-sess oi-sess-mini" data-term="codex">
                <canvas class="oi-petc oi-petc-mini" data-pet="otter"></canvas>
                <span class="oi-sess-name">backend server</span>
                <span class="oi-tag">Codex</span><span class="oi-tag">Ghostty</span><span class="oi-dur">1h</span>
              </div>
              <div class="oi-sess oi-sess-mini" data-term="gemini">
                <canvas class="oi-petc oi-petc-mini" data-pet="fox"></canvas>
                <span class="oi-sess-name">optimize queries</span>
                <span class="oi-tag">Gemini</span><span class="oi-tag">cmux</span><span class="oi-dur">5h</span>
              </div>
            </div>

            <!-- switcher: ⌃⌘Tab keyboard session switch -->
            <div class="oi-layer" data-layer="switcher">
              <div class="oi-sw-head">
                <span class="oi-keys" id="oi-sw-keys"><span class="oi-key">⌃</span><span class="oi-key">⌘</span><span class="oi-key" id="oi-sw-tab">Tab</span></span>
                <span class="oi-sw-title"><span lang="en">Switch session</span><span lang="zh">切换会话</span></span>
              </div>
              <div class="oi-sw-list">
                <div class="oi-sw-row" data-term="claude">
                  <canvas class="oi-petc oi-petc-mini" data-pet="claude"></canvas>
                  <span class="oi-sw-name">fix auth bug</span>
                  <span class="oi-tag">iTerm2</span>
                  <span class="oi-sw-badge" style="color:var(--green)"><span lang="en">done</span><span lang="zh">完成</span></span>
                </div>
                <div class="oi-sw-row" data-term="codex">
                  <canvas class="oi-petc oi-petc-mini" data-pet="otter"></canvas>
                  <span class="oi-sw-name">backend server</span>
                  <span class="oi-tag">Ghostty</span>
                  <span class="oi-sw-badge" style="color:var(--blue)"><span lang="en">running</span><span lang="zh">运行中</span></span>
                </div>
                <div class="oi-sw-row" data-term="gemini">
                  <canvas class="oi-petc oi-petc-mini" data-pet="fox"></canvas>
                  <span class="oi-sw-name">optimize queries</span>
                  <span class="oi-tag">cmux</span>
                  <span class="oi-sw-badge" style="color:var(--text-3)"><span lang="en">idle</span><span lang="zh">空闲</span></span>
                </div>
              </div>
              <div class="oi-sw-hints">
                <span><b>J/K</b> <span lang="en">cycle</span><span lang="zh">切换</span></span>
                <span><b>⌃⌘</b> <span lang="en">release</span><span lang="zh">松手跳转</span></span>
                <span><b>esc</b> <span lang="en">cancel</span><span lang="zh">取消</span></span>
              </div>
            </div>
          </div>
        </div>

        <!-- dock -->
        <div class="oi-dock">
          <div class="oi-dock-app is-on" data-scene="sessions" title="Sessions">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1.5"></rect><rect x="14" y="3" width="7" height="7" rx="1.5"></rect><rect x="3" y="14" width="7" height="7" rx="1.5"></rect><rect x="14" y="14" width="7" height="7" rx="1.5"></rect></svg>
            <span class="oi-dock-dot"></span>
          </div>
          <div class="oi-dock-app" data-scene="approval" title="Approve">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="M9 12l2 2 4-4"></path></svg>
            <span class="oi-dock-dot"></span>
          </div>
          <div class="oi-dock-app" data-scene="ask" title="Ask">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
            <span class="oi-dock-dot"></span>
          </div>
          <div class="oi-dock-app" data-scene="jump" title="Jump">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"></rect><path d="M8 21h8M12 17v4"></path></svg>
            <span class="oi-dock-dot"></span>
          </div>
          <div class="oi-dock-app" data-scene="switcher" title="Switch">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="6" width="20" height="12" rx="2"></rect><path d="M6 10h.01M10 10h.01M14 10h.01M18 10h.01M8 14h8"></path></svg>
            <span class="oi-dock-dot"></span>
          </div>
        </div>

        <!-- simulated cursor -->
        <div class="oi-cursor" id="oi-cursor">
          <svg width="15" height="19" viewBox="0 0 16 20" fill="none">
            <path d="M1 1L1 15L5 11L9 19L12 17.5L8 10L14 10L1 1Z" fill="#fff" stroke="#0b0b0d" stroke-width="1.2" stroke-linejoin="round"></path>
          </svg>
        </div>
      </div>
      <div class="oi-base"></div>
    </div>

    <!-- ===== Scene narration bar ===== -->
    <div class="oi-scene">
      <div class="oi-pills">
        <button class="oi-pill" data-scene="sessions" aria-label="Sessions scene">
          <svg class="oi-pill-icon" width="12" height="12" viewBox="0 0 8 8" shape-rendering="crispEdges"><rect x="0" y="0" width="3" height="3" fill="currentColor"></rect><rect x="5" y="0" width="3" height="3" fill="currentColor"></rect><rect x="0" y="5" width="3" height="3" fill="currentColor"></rect><rect x="5" y="5" width="3" height="3" fill="currentColor"></rect></svg>
          <span class="oi-pill-label"><span lang="en">Sessions</span><span lang="zh">会话</span></span>
        </button>
        <button class="oi-pill" data-scene="approval" aria-label="Approve scene">
          <svg class="oi-pill-icon" width="12" height="12" viewBox="0 0 8 8" shape-rendering="crispEdges"><rect x="2" y="1" width="4" height="1" fill="currentColor"></rect><rect x="1" y="2" width="6" height="3" fill="currentColor"></rect><rect x="2" y="5" width="4" height="1" fill="currentColor"></rect><rect x="3" y="6" width="2" height="1" fill="currentColor"></rect></svg>
          <span class="oi-pill-label"><span lang="en">Approve</span><span lang="zh">批准</span></span>
        </button>
        <button class="oi-pill" data-scene="ask" aria-label="Ask scene">
          <svg class="oi-pill-icon" width="12" height="12" viewBox="0 0 8 8" shape-rendering="crispEdges"><rect x="0" y="1" width="8" height="3" fill="currentColor"></rect><rect x="1" y="4" width="6" height="1" fill="currentColor"></rect><rect x="1" y="5" width="2" height="1" fill="currentColor"></rect></svg>
          <span class="oi-pill-label"><span lang="en">Ask</span><span lang="zh">提问</span></span>
        </button>
        <button class="oi-pill" data-scene="jump" aria-label="Jump scene">
          <svg class="oi-pill-icon" width="12" height="12" viewBox="0 0 8 8" shape-rendering="crispEdges"><rect x="4" y="1" width="1" height="1" fill="currentColor"></rect><rect x="5" y="2" width="1" height="1" fill="currentColor"></rect><rect x="1" y="3" width="5" height="1" fill="currentColor"></rect><rect x="5" y="4" width="1" height="1" fill="currentColor"></rect><rect x="4" y="5" width="1" height="1" fill="currentColor"></rect></svg>
          <span class="oi-pill-label"><span lang="en">Jump</span><span lang="zh">跳回</span></span>
        </button>
        <button class="oi-pill" data-scene="switcher" aria-label="Switcher scene">
          <svg class="oi-pill-icon" width="12" height="12" viewBox="0 0 8 8" shape-rendering="crispEdges"><rect x="0" y="2" width="2" height="2" fill="currentColor"></rect><rect x="3" y="2" width="2" height="2" fill="currentColor"></rect><rect x="6" y="2" width="2" height="2" fill="currentColor"></rect><rect x="1" y="5" width="6" height="1" fill="currentColor"></rect></svg>
          <span class="oi-pill-label"><span lang="en">Switch</span><span lang="zh">切换</span></span>
        </button>
      </div>
      <div class="oi-scene-title" id="oi-scene-title"><span lang="en"></span><span lang="zh"></span></div>
      <div class="oi-scene-desc" id="oi-scene-desc"><span lang="en"></span><span lang="zh"></span></div>
    </div>
  </div>
</section>

<style>
  .oi-head {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 36px;
  }
  .oi-head .section-sub { margin: 0 auto; }

  .oi-stage { width: 100%; max-width: 940px; margin: 0 auto; }
  .oi-laptop { position: relative; }

  /* ---- screen ---- */
  .oi-screen {
    position: relative;
    aspect-ratio: 16 / 10;
    border-radius: 16px 16px 10px 10px;
    border: 1px solid var(--border-2);
    overflow: hidden;
    background:
      radial-gradient(130% 80% at 50% -12%, rgba(255, 176, 0, 0.12), transparent 52%),
      radial-gradient(90% 70% at 84% 112%, rgba(87, 151, 255, 0.08), transparent 60%),
      linear-gradient(180deg, #15151a, #0b0b0e);
    box-shadow: 0 40px 110px rgba(0, 0, 0, 0.55), inset 0 1px rgba(255, 255, 255, 0.05);
  }
  .oi-wall {
    position: absolute; inset: 0; z-index: 0; pointer-events: none;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 18px 18px;
    opacity: 0.4;
    -webkit-mask-image: radial-gradient(130% 120% at 50% 0%, #000 50%, transparent 96%);
    mask-image: radial-gradient(130% 120% at 50% 0%, #000 50%, transparent 96%);
  }
  .oi-scan {
    position: absolute; inset: 0; z-index: 1; pointer-events: none;
    background: repeating-linear-gradient(to bottom, rgba(255,255,255,0.022) 0 1px, transparent 1px 3px);
    mix-blend-mode: overlay; opacity: 0.5;
  }
  .oi-base {
    height: 13px; margin: 0 7%;
    background: linear-gradient(180deg, #2a2a30, #18181c);
    border-radius: 0 0 12px 12px;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.4);
    position: relative;
  }
  .oi-base::after {
    content: ''; position: absolute; top: 0; left: 50%; transform: translateX(-50%);
    width: 15%; height: 4px; background: rgba(0, 0, 0, 0.45); border-radius: 0 0 5px 5px;
  }

  /* ---- menu bar ---- */
  .oi-menubar {
    position: absolute; top: 0; left: 0; right: 0; z-index: 9; height: 26px;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 12px; font-family: var(--mono); font-size: 11px; color: var(--text-2);
    background: rgba(8, 8, 10, 0.55); backdrop-filter: blur(8px);
  }
  .oi-mb-l { display: flex; align-items: center; gap: 13px; }
  .oi-mb-mark { display: inline-flex; }
  .oi-mb-app { color: var(--text); font-weight: 700; }
  .oi-mb-menu { color: var(--text-2); }
  .oi-mb-r { display: flex; align-items: center; gap: 11px; }
  .oi-mb-glyph { color: var(--text-2); }
  #oi-clock { color: var(--text); font-variant-numeric: tabular-nums; letter-spacing: 0.02em; }

  /* ---- desktop terminals ---- */
  .oi-desktop { position: absolute; inset: 28px 0 14px; z-index: 4; }
  .oi-term {
    position: absolute;
    border-radius: 9px; overflow: hidden;
    background: rgba(11, 11, 14, 0.9);
    border: 1px solid var(--border-2);
    box-shadow: 0 16px 36px rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(8px);
    transition: opacity 0.5s ease, transform 0.55s cubic-bezier(0.34, 1.4, 0.64, 1);
  }
  .oi-term-claude { left: 30%; top: 30%; width: 41%; z-index: 3; }
