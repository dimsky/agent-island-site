        var p = Math.min((now - start) / dur, 1);
        var e = 1 - Math.pow(1 - p, 3);
        var b = 1 - e;
        var nx = b * b * x0 + 2 * b * e * cx + e * e * x;
        var ny = b * b * y0 + 2 * b * e * cy + e * e * y;
        cursor.style.left = nx.toFixed(2) + '%';
        cursor.style.top = ny.toFixed(2) + '%';
