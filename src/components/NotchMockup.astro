    /* ---------- simulated cursor (quadratic bezier, RAF) ---------- */
    var raf = null;
    function jit() { return (Math.random() - 0.5) * 2; }
    function moveCursor(xPct, yPct, show) {
      if (!cursor) return;
      cursor.style.opacity = show ? '1' : '0';
      var x = xPct, y = yPct;
      if (isNaN(x) || isNaN(y)) return;
      var x0 = parseFloat(cursor.style.left), y0 = parseFloat(cursor.style.top);
      if (isNaN(x0)) x0 = 52;
      if (isNaN(y0)) y0 = 62;
      if (raf) { cancelAnimationFrame(raf); raf = null; }
      var dx = x - x0, dy = y - y0, dist = Math.sqrt(dx * dx + dy * dy);
      if (!show || dist < 0.4) {
        cursor.style.left = x.toFixed(2) + '%';
        cursor.style.top = y.toFixed(2) + '%';
        return;
      }
      var far = dist > 6;
      var cx = (x0 + x) / 2 + (far ? jit() * Math.min(dist * 0.35, 7) : 0);
      var cy = (y0 + y) / 2 + (far ? jit() * Math.min(dist * 0.25, 5) : 0);
      var dur = Math.min(900, 360 + dist * 9);
      var start = performance.now();
